---
const { user } = Astro.locals;
---

<div
  class="flex items-center justify-between px-4 py-2 mb-4 rounded-xl bg-white/5 border border-white/10 text-sm text-white/80"
>
  {
    user ? (
      <>
        <span class="text-blue-100/70">{user.email}</span>
        <div class="flex items-center gap-3">
          <a href="/dashboard" class="text-purple-300 hover:text-purple-100 hover:underline transition-colors">
            Dashboard
          </a>
          <form method="POST" action="/api/auth/signout">
            <button type="submit" class="text-purple-300 hover:text-purple-100 hover:underline transition-colors">
              Sign out
            </button>
          </form>
        </div>
      </>
    ) : (
      <>
        <span class="text-blue-100/70">Not signed in</span>
        <div class="flex gap-3">
          <a href="/auth/signin" class="text-purple-300 hover:text-purple-100 hover:underline transition-colors">
            Sign in
          </a>
          <a href="/auth/signup" class="text-purple-300 hover:text-purple-100 hover:underline transition-colors">
            Sign up
          </a>
        </div>
      </>
    )
  }
</div>
