---
import Layout from "../layouts/Layout.astro";
import LoginForm from "../components/LoginForm";

// Check if user is already logged in
const { user } = Astro.locals;
if (user) {
  // Redirect authenticated users to generate page
  return Astro.redirect("/generate");
}

// Obsługa komunikatu sukcesu (np. po resecie hasła)
const successMessage = Astro.url.searchParams.get('message');
---

<Layout title="Logowanie - 10x-cards">
  <main
    class="flex min-h-screen items-center justify-center px-4 bg-gradient-to-br from-slate-50 to-slate-100 dark:from-slate-900 dark:to-slate-800"
  >
    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <h1 class="text-3xl font-bold text-slate-900 dark:text-slate-100">Zaloguj się</h1>
        <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">Wpisz swoje dane aby kontynuować</p>
      </div>
      <div class="bg-white dark:bg-slate-800 rounded-lg shadow-lg p-8">
        {successMessage && (
          <div
            role="alert"
            class="mb-4 p-3 bg-green-50 border border-green-200 rounded-md dark:bg-green-900/20 dark:border-green-800"
          >
            <p class="text-sm text-green-600 dark:text-green-400">{successMessage}</p>
          </div>
        )}
        <LoginForm client:load />
      </div>
    </div>
  </main>
</Layout>
