---
import Layout from "../layouts/Layout.astro";

// Placeholder page for /login
// TODO: Implement login view
---

<Layout title="Logowanie - 10x-cards">
  <main
    class="flex min-h-screen items-center justify-center px-4 bg-gradient-to-br from-slate-50 to-slate-100 dark:from-slate-900 dark:to-slate-800"
  >
    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <h1 class="text-3xl font-bold text-slate-900 dark:text-slate-100">Zaloguj się</h1>
        <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">Ta strona jest w trakcie implementacji</p>
      </div>
      <div class="bg-white dark:bg-slate-800 rounded-lg shadow-lg p-8">
        <div class="text-center space-y-4">
          <p class="text-slate-600 dark:text-slate-400">Widok logowania będzie dostępny wkrótce.</p>
          <p class="text-center text-sm text-slate-600 dark:text-slate-400">
            Nie masz konta? <a href="/register" class="font-medium text-primary hover:underline">Zarejestruj się</a>
          </p>
        </div>
      </div>
    </div>
  </main>
</Layout>
