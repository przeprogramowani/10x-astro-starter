---
import Layout from "../layouts/Layout.astro";
import ResetPasswordForm from "../components/ResetPasswordForm";

/**
 * Strona resetowania hasła
 * 
 * Supabase automatycznie loguje użytkownika gdy klika link z emaila.
 * Token jest w URL jako fragment (#access_token=...) i jest obsługiwany
 * przez Supabase client automatycznie.
 * 
 * Ta strona jest dostępna tylko dla użytkowników, którzy kliknęli
 * w link resetujący z emaila. Fragment URL z tokenem zostanie
 * przetworzony przez ResetPasswordForm po stronie klienta.
 */

// Sprawdź czy użytkownik jest zalogowany (co oznacza, że token był ważny)
// Jeśli nie, przekieruj na stronę forgot-password
const { user } = Astro.locals;

// Supabase automatycznie zaloguje użytkownika przy kliknięciu linku
// Jednak w SSR możemy nie mieć jeszcze sesji, więc sprawdzamy to po stronie klienta
// Tutaj przekazujemy tylko informację czy strona została załadowana poprawnie
const hasError = Astro.url.searchParams.get('error');
const errorDescription = Astro.url.searchParams.get('error_description');

// Jeśli jest błąd w URL (np. token wygasł), przekieruj
if (hasError) {
  return Astro.redirect('/forgot-password?error=' + encodeURIComponent(errorDescription || 'Link wygasł'));
}
---

<Layout title="Ustaw nowe hasło - 10x-cards">
  <main
    class="flex min-h-screen items-center justify-center px-4 bg-gradient-to-br from-slate-50 to-slate-100 dark:from-slate-900 dark:to-slate-800"
  >
    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <h1 class="text-3xl font-bold text-slate-900 dark:text-slate-100">Ustaw nowe hasło</h1>
        <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">Wpisz nowe hasło dla swojego konta</p>
      </div>
      <div class="bg-white dark:bg-slate-800 rounded-lg shadow-lg p-8">
        <ResetPasswordForm client:load />
      </div>
    </div>
  </main>
</Layout>
