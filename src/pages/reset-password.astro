---
import Layout from "../layouts/Layout.astro";
import ResetPasswordForm from "../components/ResetPasswordForm";

// TODO: Backend - Odczyt tokenu resetowania z URL
// const token = Astro.url.searchParams.get('token');
//
// // Walidacja obecności tokenu
// if (!token) {
//   return Astro.redirect('/forgot-password');
// }

// Placeholder token dla UI
const token = "placeholder-token";
---

<Layout title="Ustaw nowe hasło - 10x-cards">
  <main
    class="flex min-h-screen items-center justify-center px-4 bg-gradient-to-br from-slate-50 to-slate-100 dark:from-slate-900 dark:to-slate-800"
  >
    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <h1 class="text-3xl font-bold text-slate-900 dark:text-slate-100">Ustaw nowe hasło</h1>
        <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">Wpisz nowe hasło dla swojego konta</p>
      </div>
      <div class="bg-white dark:bg-slate-800 rounded-lg shadow-lg p-8">
        <ResetPasswordForm client:load token={token} />
      </div>
    </div>
  </main>
</Layout>
